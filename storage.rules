rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── GPX de rutas realizadas y propuestas ───────────────────
    // Lectura pública con token (getDownloadURL); escritura solo autenticados
    match /gpx/{filename} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Todo lo demás: solo autenticados ──────────────────────
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
