rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    // ── GPX de rutas realizadas y propuestas ───────────────────
    // Lectura pública; escritura solo admin
    match /gpx/{filename} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Todo lo demás: lectura autenticada, escritura solo admin ──
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
